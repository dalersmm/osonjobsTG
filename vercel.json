{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    },
    {
      "src": "/api/jobs",
      "dest": "/api/jobs.py"
    },
    {
      "src": "/api/referral",
      "dest": "/api/referral.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}